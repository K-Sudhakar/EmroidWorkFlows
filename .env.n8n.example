# n8n runtime environment values used by the imported workflow.
# Do not commit real tokens or production secrets.

# n8n-to-FastAPI API base URL. Do not include a trailing slash.
# If n8n runs in Docker and FastAPI runs on the host:
BACKEND_API_BASE_URL=http://host.docker.internal:8000

# Public n8n base URL used for Telegram webhooks and backend callback URLs.
# For local development, use an HTTPS tunnel URL.
WEBHOOK_URL=https://n8n.example.com/
