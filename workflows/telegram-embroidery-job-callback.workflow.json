    {
      "parameters": {
        "jsCode": "const original = $('Normalize Telegram Message').first().json;\nconst body = $json.body || $json;\nconst detail = body.detail;\nconst detailText = Array.isArray(detail) ? 'The backend rejected the uploaded file.' : (detail || body.safe_error || body.error || '');\nconst jobId = body.job_id || '';\nreturn [{\n  json: {\n    ...original,\n    job_id: jobId,\n    status: body.status || (jobId ? 'queued' : 'failed'),\n    download_url: body.download_url || '',\n    file_name: body.file_name || body.output_filename || '',\n    safe_error: jobId ? '' : (detailText || 'The backend did not accept the job.'),\n    backend_create_response: body\n  }\n}];"
      },
