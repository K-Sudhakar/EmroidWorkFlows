    {
      "parameters": {
        "jsCode": "const created = $('Normalize Job Response').first().json;\nconst body = $json.body || $json;\nlet status = String(body.status || created.status || '').toLowerCase();\nif (['complete', 'completed', 'done', 'success', 'succeeded'].includes(status)) status = 'completed';\nif (['failed', 'error', 'errored', 'cancelled', 'canceled'].includes(status)) status = 'failed';\nconst detail = body.detail;\nconst safeError = Array.isArray(detail) ? 'The backend rejected the job status request.' : (body.safe_error || body.error_message || body.error || detail || created.safe_error || 'The backend reported a processing error.');\nreturn [{\n  json: {\n    ...created,\n    status,\n    download_url: body.download_url || created.download_url || '',\n    file_name: body.file_name || body.output_filename || created.file_name || '',\n    safe_error: status === 'failed' ? safeError : '',\n    backend_status_response: body\n  }\n}];"
      },
