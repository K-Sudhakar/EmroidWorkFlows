    {
      "parameters": {
        "jsCode": "const backendApiBaseUrl = 'http://72.60.97.242:8000/';\nconst publicN8nBaseUrl = 'https://n8n.paxgeek.com/';\nconst update = $json;\nconst message = update.message || update.edited_message || update.channel_post || {};\nconst chat = message.chat || {};\nconst from = message.from || {};\nconst document = message.document || {};\nconst text = (message.text || '').trim();\nconst binary = $binary || {};\nconst binaryFile = binary.data || {};\nconst fileName = document.file_name || binaryFile.fileName || '';\nconst mimeType = document.mime_type || binaryFile.mimeType || '';\nconst lowerFileName = fileName.toLowerCase();\nconst isSvgDocument = Boolean(document.file_id) && (lowerFileName.endsWith('.svg') || mimeType === 'image/svg+xml');\nlet route = 'unsupported';\nif (text === '/start' || text.startsWith('/start ')) route = 'start_help';\nif (text === '/help' || text.startsWith('/help ')) route = 'start_help';\nif (isSvgDocument) route = 'svg_file';\nreturn [{\n  json: {\n    update_id: update.update_id,\n    message_id: message.message_id,\n    chat_id: chat.id ? String(chat.id) : '',\n    user_id: from.id ? String(from.id) : '',\n    username: from.username || '',\n    route,\n    text,\n    file_id: document.file_id || '',\n    file_name: fileName,\n    mime_type: mimeType,\n    source: 'telegram',\n    received_at: new Date().toISOString(),\n    config: {\n      backend_api_base_url: backendApiBaseUrl.replace(/\\/$/, ''),\n      public_n8n_base_url: publicN8nBaseUrl.replace(/\\/$/, '')\n    }\n  },\n  binary\n}];"
      },
